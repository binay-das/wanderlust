<%= layout('/layouts/boilerplate') %>

    <style>
        body {
            background: #f7f5f2;
        }

        .auth-wrap {
            min-height: calc(100vh - 64px - 200px);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
        }

        .auth-card {
            background: #fff;
            border-radius: 22px;
            padding: 2.5rem 2.2rem;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 8px 40px rgba(0, 0, 0, 0.10);
        }

        .auth-icon {
            width: 52px;
            height: 52px;
            background: linear-gradient(135deg, #fe424d, #ff6b6b);
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.3rem;
            margin-bottom: 1.2rem;
        }

        .auth-title {
            font-size: 1.5rem;
            font-weight: 800;
            color: #1a1a1a;
            margin-bottom: 0.3rem;
        }

        .auth-sub {
            font-size: 0.88rem;
            color: #999;
            margin-bottom: 1.8rem;
        }

        .auth-label {
            font-size: 0.8rem;
            font-weight: 700;
            color: #555;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            margin-bottom: 0.35rem;
            display: block;
        }

        .auth-input {
            width: 100%;
            border: 1.5px solid #e8e8e8;
            border-radius: 10px;
            padding: 11px 14px;
            font-size: 0.95rem;
            color: #222;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
            background: #fafafa;
            margin-bottom: 1.1rem;
        }

        .auth-input:focus {
            border-color: #fe424d;
            box-shadow: 0 0 0 3px rgba(254, 66, 77, 0.1);
            background: #fff;
        }

        .auth-submit {
            width: 100%;
            padding: 12px;
            border-radius: 10px;
            background: linear-gradient(135deg, #fe424d, #ff5e5e);
            color: #fff;
            font-size: 1rem;
            font-weight: 700;
            border: none;
            cursor: pointer;
            transition: opacity 0.2s, transform 0.15s;
            margin-top: 0.4rem;
        }

        .auth-submit:hover {
            opacity: 0.92;
            transform: translateY(-1px);
        }

        .auth-submit:active {
            transform: translateY(0);
        }

        .auth-footer-text {
            text-align: center;
            margin-top: 1.4rem;
            font-size: 0.87rem;
            color: #999;
        }

        .auth-footer-text a {
            color: #fe424d;
            font-weight: 600;
            text-decoration: none;
        }

        .auth-footer-text a:hover {
            text-decoration: underline;
        }

        .auth-hint {
            font-size: 0.75rem;
            color: #bbb;
            margin-top: -0.7rem;
            margin-bottom: 1rem;
            display: block;
        }
    </style>

    <div class="auth-wrap">
        <div class="auth-card">
            <div class="auth-icon"><i class="fa-solid fa-user-plus"></i></div>
            <div class="auth-title">Create an account</div>
            <div class="auth-sub">Join Wanderlust and start exploring</div>

            <form action="/signup" method="post" class="needs-validation" novalidate>
                <label class="auth-label" for="username">Username</label>
                <input type="text" name="username" id="username" class="auth-input" placeholder="Choose a username"
                    required autocomplete="username">

                <label class="auth-label" for="email">Email address</label>
                <input type="email" name="email" id="email" class="auth-input" placeholder="you@example.com" required
                    autocomplete="email">

                <label class="auth-label" for="password">Password</label>
                <input type="password" name="password" id="password" class="auth-input"
                    placeholder="Create a strong password" required autocomplete="new-password">
                <span class="auth-hint">At least 8 characters recommended</span>

                <button type="submit" class="auth-submit">
                    <i class="fa-solid fa-rocket me-2"></i>Create Account
                </button>
            </form>

            <div class="auth-footer-text">
                Already have an account? <a href="/login">Log in</a>
            </div>
        </div>
    </div>