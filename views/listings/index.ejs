<%= layout('/layouts/boilerplate') %>

    <style>
        body {
            background-color: #f7f5f2;
        }


        .filter-bar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            margin: 1.5rem 0 1.8rem;
            flex-wrap: wrap;
        }

        .filters-scroll {
            display: flex;
            gap: 0.6rem;
            overflow-x: auto;
            flex: 1;
            scrollbar-width: none;
            padding-bottom: 4px;
        }

        .filters-scroll::-webkit-scrollbar {
            display: none;
        }

        .filter-chip {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            padding: 8px 16px;
            border-radius: 30px;
            border: 1.5px solid #e0e0e0;
            background: #fff;
            cursor: pointer;
            transition: all 0.2s ease;
            white-space: nowrap;
            font-size: 0.75rem;
            font-weight: 500;
            color: #555;
            box-shadow: 0 1px 4px rgba(0, 0, 0, 0.06);
            flex-shrink: 0;
        }

        .filter-chip i {
            font-size: 1.05rem;
            color: #888;
            transition: color 0.2s;
        }

        .filter-chip:hover,
        .filter-chip.active {
            border-color: #fe424d;
            background: #fff0f0;
            color: #fe424d;
            box-shadow: 0 2px 10px rgba(254, 66, 77, 0.15);
        }

        .filter-chip:hover i,
        .filter-chip.active i {
            color: #fe424d;
        }

        .tax-toggle {
            white-space: nowrap;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.85rem;
            font-weight: 500;
            color: #555;
            flex-shrink: 0;
        }

        .form-check-input:checked {
            background-color: #fe424d !important;
            border-color: #fe424d !important;
        }


        .listings-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
            gap: 1.8rem;
            padding-bottom: 3rem;
        }


        .listing-item {
            background: #fff;
            border-radius: 18px;
            overflow: hidden;
            box-shadow: 0 2px 12px rgba(0, 0, 0, 0.07);
            transition: transform 0.25s ease, box-shadow 0.25s ease;
            cursor: pointer;
            position: relative;
            text-decoration: none;
            color: inherit;
            display: block;
        }

        .listing-item:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 32px rgba(0, 0, 0, 0.13);
        }

        .listing-img-wrap {
            position: relative;
            overflow: hidden;
            height: 210px;
        }

        .listing-img-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.4s ease;
            display: block;
        }

        .listing-item:hover .listing-img-wrap img {
            transform: scale(1.06);
        }


        .listing-heart {
            position: absolute;
            top: 12px;
            right: 14px;
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.88);
            backdrop-filter: blur(4px);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.9rem;
            color: #ccc;
            cursor: pointer;
            border: none;
            transition: color 0.2s, transform 0.2s;
            z-index: 2;
        }

        .listing-heart:hover {
            color: #fe424d;
            transform: scale(1.15);
        }

        .listing-country-badge {
            position: absolute;
            bottom: 10px;
            left: 12px;
            background: rgba(0, 0, 0, 0.55);
            backdrop-filter: blur(6px);
            color: #fff;
            font-size: 0.7rem;
            font-weight: 600;
            padding: 3px 10px;
            border-radius: 20px;
            letter-spacing: 0.05em;
        }

        .listing-body {
            padding: 1rem 1.1rem 1.2rem;
        }

        .listing-title {
            font-size: 0.98rem;
            font-weight: 700;
            color: #1a1a1a;
            margin-bottom: 3px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .listing-location {
            font-size: 0.8rem;
            color: #888;
            margin-bottom: 0.7rem;
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .listing-location i {
            color: #fe424d;
            font-size: 0.72rem;
        }

        .listing-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-top: 0.3rem;
        }

        .listing-price {
            font-size: 1rem;
            font-weight: 700;
            color: #1a1a1a;
        }

        .listing-price span {
            font-size: 0.78rem;
            font-weight: 400;
            color: #999;
        }

        .listing-tax {
            font-size: 0.72rem;
            color: #aaa;
            display: none;
        }

        .listing-tax.show {
            display: block;
        }

        .listing-view-btn {
            font-size: 0.78rem;
            font-weight: 600;
            color: #fe424d;
            background: #fff0f0;
            border: 1.5px solid #ffd5d7;
            border-radius: 20px;
            padding: 4px 12px;
            text-decoration: none;
            transition: all 0.2s;
        }

        .listing-view-btn:hover {
            background: #fe424d;
            color: #fff;
            border-color: #fe424d;
        }

        .no-listings {
            grid-column: 1 / -1;
            text-align: center;
            padding: 5rem 0;
            color: #aaa;
        }

        .no-listings i {
            font-size: 3rem;
            margin-bottom: 1rem;
        }

        .no-listings p {
            font-size: 1rem;
        }
    </style>


<div class="filter-bar">
        <div class="filters-scroll">
            <div class="filter-chip" data-category="Trending">
                <i class="fa-solid fa-fire"></i>
                <span>Trending</span>
            </div>
            <div class="filter-chip" data-category="Rooms">
                <i class="fa-solid fa-bed"></i>
                <span>Rooms</span>
            </div>
            <div class="filter-chip" data-category="Iconic cities">
                <i class="fa-solid fa-mountain-city"></i>
                <span>Iconic cities</span>
            </div>
            <div class="filter-chip" data-category="Mountains">
                <i class="fa-solid fa-mountain"></i>
                <span>Mountains</span>
            </div>
            <div class="filter-chip" data-category="Near Castles">
                <i class="fa-brands fa-fort-awesome"></i>
                <span>Near Castles</span>
            </div>
            <div class="filter-chip" data-category="Camping">
                <i class="fa-solid fa-campground"></i>
                <span>Camping</span>
            </div>
            <div class="filter-chip" data-category="Pools">
                <i class="fa-solid fa-person-swimming"></i>
                <span>Pools</span>
            </div>
            <div class="filter-chip" data-category="Arctic">
                <i class="fa-regular fa-snowflake"></i>
                <span>Arctic</span>
            </div>
            <div class="filter-chip" data-category="Caves">
                <i class="fa-solid fa-igloo"></i>
                <span>Caves</span>
            </div>
            <div class="filter-chip" data-category="Boating">
                <i class="fa-solid fa-ship"></i>
                <span>Boating</span>
            </div>
        </div>

        <div class="tax-toggle">
            <div class="form-check form-switch mb-0">
                <input class="form-check-input" type="checkbox" role="switch" id="taxToggle">
                <label class="form-check-label" for="taxToggle">Show taxes</label>
            </div>
        </div>
    </div>


    <div class="listings-grid">
        <% if(allListings.length===0) { %>
            <div class="no-listings">
                <i class="fa-regular fa-compass"></i>
                <p>No listings found. Be the first to <a href="/listings/new" style="color:#fe424d;">add one!</a></p>
            </div>
            <% } %>

                <% for(let listing of allListings) { %>
                    <a href="/listings/<%= listing.id %>" class="listing-item">
                        <div class="listing-img-wrap">
                            <img src="<%= listing.image.url %>" alt="<%= listing.title %>">
                            <button class="listing-heart" onclick="event.preventDefault()">
                                <i class="fa-regular fa-heart"></i>
                            </button>
                            <div class="listing-country-badge">
                                <i class="fa fa-globe me-1"></i>
                                <%= listing.country %>
                            </div>
                        </div>
                        <div class="listing-body">
                            <div class="listing-title">
                                <%= listing.title %>
                            </div>
                            <div class="listing-location">
                                <i class="fa-solid fa-location-dot"></i>
                                <%= listing.location %>
                            </div>
                            <div class="listing-footer">
                                <div>
                                    <div class="listing-price">
                                        &#8377;<%= listing.price.toLocaleString("en-IN") %> <span>/ night</span>
                                    </div>
                                    <div class="listing-tax">+18% GST</div>
                                </div>
                                <span class="listing-view-btn">View &rarr;</span>
                            </div>
                        </div>
                    </a>
                    <% } %>
    </div>

    <script>

document.querySelectorAll('.filter-chip').forEach(chip => {
            chip.addEventListener('click', () => {
                document.querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
                chip.classList.add('active');
            });
        });

       
        document.getElementById('taxToggle').addEventListener('change', function () {
            document.querySelectorAll('.listing-tax').forEach(el => {
                el.classList.toggle('show', this.checked);
            });
        });
    </script>